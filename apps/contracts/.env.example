# ── 배포자 계정 (테스트넷 전용 – 실제 자산 없는 지갑 사용)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── TEE 서명 주소 (NEAR AI TEE 에서 생성한 ECDSA 공개키의 Ethereum 주소)
TEE_SIGNER_ADDRESS=0xTEE_SIGNER_ADDRESS_HERE

# ── BSCScan / opBNBScan API 키 (컨트랙트 검증용)
BSCSCAN_API_KEY=YOUR_BSCSCAN_API_KEY
OPBNBSCAN_API_KEY=YOUR_OPBNBSCAN_API_KEY

# ── 선택: 배포 후 컨트랙트 주소 (프론트 / TEE 연동 시 사용)
# ESCROW_CONTRACT_ADDRESS=0x...
